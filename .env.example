# Required to access /admin. Must be a bcrypt hash of your chosen password.
# Generate with: node -e "const b=require('bcryptjs');console.log(b.hashSync('<your-password>',12))"
ADMIN_PASSWORD_HASH=

# Required in production. Used to sign the admin session cookie.
# Generate with: openssl rand -hex 32
ADMIN_SESSION_SECRET=

# Required in production. Used to encrypt optional reporter emails at rest.
# Generate with: openssl rand -hex 32
EMAIL_ENCRYPTION_SECRET=

# Optional. Absolute path for the SQLite database file.
# Defaults to <project>/data/sau-incidence-reporting.db
DATABASE_PATH=
